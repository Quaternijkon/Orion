{
  "matrix_name": "method4_distributed_glove200_initial",
  "harness": "tools/qdrant_two_level_routing_experiment.py",
  "python": "/users/dry/orion-distributed/venv/bin/python",
  "output_root": "results/method4_distributed",
  "client_cpuset": "8-19",
  "confirmation_targets": [0.9, 0.95],
  "defaults": {
    "base_url": "http://10.10.1.1:6333",
    "hdf5_path": "/users/dry/orion-distributed/datasets/glove-200-angular.hdf5",
    "cluster_topology": "tools/distributed/cloudlab_orion_4node.json",
    "deployment_manifest": "/proj/intelisys-PG0/exp/orion-distributed/{matrix_run_id}/manifest.json",
    "require_clean_runtime": true,
    "vector_distance": "cosine",
    "top_k": 10,
    "hnsw_m": 32,
    "ef_construct": 100,
    "upper_m": 32,
    "upper_ef_construction": 100,
    "upper_search_ef": 400,
    "sample_denominator": 32,
    "k_overlap": 10,
    "upper_sample_seed": 100,
    "kmeans_rand_seed": 1,
    "kmeans_iters": 10,
    "tuning_query_count": 500,
    "eval_query_count": 500,
    "warmup_query_count": 200,
    "stability_repeats": 0,
    "batch_size": 100,
    "target_recall": 0.0,
    "write_per_query_metrics": true,
    "search_dispatch_mode": "coordinator",
    "shard_placement": "round_robin"
  },
  "cases": [
    {
      "name": "orion",
      "preset": "orion",
      "collection_template": "dist_{matrix_run_id}_orion_s46",
      "args": {
        "num_shards": 31,
        "upper_k_candidates": [24, 60, 80, 120, 160],
        "base_ef_candidates": [32, 40, 60, 80],
        "factor_candidates": [6, 8, 10, 12],
        "disable_multi_assign": false,
        "disable_fission": false,
        "routed_execution_mode": "compact_multi_ep",
        "routed_planning_mode": "materialized",
        "routed_result_limit_mode": "top_k",
        "physical_execution_trace": true
      }
    },
    {
      "name": "simple_kmeans",
      "preset": "kmeans_simple_nprobe",
      "collection_template": "dist_{matrix_run_id}_simple_kmeans_s46",
      "args": {
        "num_shards": 46,
        "nprobe_candidates": [8, 16, 24, 32, 40, 46],
        "upper_k_candidates": [8, 16, 24, 32, 40, 46],
        "base_ef_candidates": [32, 48, 64, 80, 120, 160, 240],
        "factor_candidates": [0],
        "simple_kmeans_multi_assign_alpha": 1.0
      }
    },
    {
      "name": "naive",
      "preset": "naive",
      "collection_template": "dist_{matrix_run_id}_naive_s46",
      "args": {
        "num_shards": 46,
        "base_ef_candidates": [20, 32, 48, 64, 76, 88, 112],
        "factor_candidates": [0]
      }
    }
  ]
}
